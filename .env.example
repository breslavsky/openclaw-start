# OpenClaw Configuration
# Copy this to .env and fill in your values
# Then reference these in ~/.openclaw/openclaw.json using ${VAR_NAME}

# OpenRouter API Key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Telegram Bot Token (if using Telegram channel)
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram User ID (allowlist - get from @userinfobot)
TELEGRAM_ALLOWED_USER_ID=123456789

# Agent workspace folder name (used in openclaw.json workspace path)
AGENT_FOLDER_NAME=tony

# Gateway Auth Token (optional - for remote access)
GATEWAY_AUTH_TOKEN=xyz
